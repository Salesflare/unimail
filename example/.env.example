# Copy this file to `.env` in the same folder and fill in the values for the
# connectors you want to try out. Connectors with missing config are skipped at
# startup, so you don't have to fill in all of them.

# Gmail (https://console.cloud.google.com/)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Office 365 (https://entra.microsoft.com/)
OFFICE365_CLIENT_ID=
OFFICE365_CLIENT_SECRET=

# Unipile
UNIPILE_BASE_URL=
UNIPILE_ACCESS_TOKEN=

PORT=3000
